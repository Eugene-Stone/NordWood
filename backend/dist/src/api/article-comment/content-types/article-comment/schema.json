{
    "kind": "collectionType",
    "collectionName": "article_comments",
    "info": {
        "singularName": "article-comment",
        "pluralName": "article-comments",
        "displayName": "Article comments"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "title": {
            "type": "string",
            "default": "Комментарий"
        },
        "text": {
            "type": "text"
        },
        "user": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "plugin::users-permissions.user",
            "inversedBy": "article_comments"
        },
        "article": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::article.article",
            "inversedBy": "article_comments"
        },
        "isApproved": {
            "type": "boolean",
            "default": false
        }
    }
}
