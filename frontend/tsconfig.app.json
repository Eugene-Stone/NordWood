{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"target": "es2023",
		"lib": ["ES2023", "DOM"],
		"module": "esnext",
		"types": ["vite/client"],
		"allowArbitraryExtensions": true,
		"skipLibCheck": true, // Github actions

		/* Bundler mode */
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": false, // Github actions
		"moduleDetection": "force",
		"noEmit": true,
		"jsx": "react-jsx",

		/* Linting */
		"noUnusedLocals": false,
		"noUnusedParameters": false,
		"erasableSyntaxOnly": false, // Github actions
		"noFallthroughCasesInSwitch": true,

		/* Импорт типов из бекенда */
		"paths": {
			"@backend-types/*": ["../backend/*"]
		}
	},
	"include": ["src"],
	"exclude": ["../backend"] // Github actions
}
